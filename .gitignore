# Python caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Local IDE and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Local paper drafting notes
paper_notes/

