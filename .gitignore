# Generated model artifacts
models/**/*.joblib
models/**/*.pkl
models/**/*.pt
models/**/*.pth

# Generated figures
figures/**/*.png
figures/**/*.jpg
figures/**/*.jpeg
figures/**/*.svg
figures/**/*.pdf

# Generated experiment outputs
results/**/*.csv
results/**/*.json
results/**/*.txt

# Keep placeholder files
!**/.gitkeep
